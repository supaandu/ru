{
  "manifest_version": 3,
  "name": "RU",
  "version": "1.0.0",
  "description": "Block distracting sites and redirect your energy.",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RU"
  }
}
