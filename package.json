{
  "name": "ru",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "build": {
    "appId": "com.ru.app",
    "productName": "RU",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "files": [
      "**/*"
    ],
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*",
      "node_modules/node-gyp-build/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4",
    "ws": "^8.20.0"
  }
}
